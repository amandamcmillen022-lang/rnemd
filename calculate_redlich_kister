plt.figure(figsize=(7,4))

plt.scatter(
    range(len(errors)),
    errors
)

plt.axhline(0)

plt.xlabel("Composition index")
plt.ylabel("RK - MD (W/mK)")

plt.title("Redlich-Kister Fit 3 Residuals")

plt.tight_layout()

plt.savefig(
    "rk_fit3_residuals.png",
    dpi=300
)

plt.close()



