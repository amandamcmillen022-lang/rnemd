plt.figure(figsize=(6,6))

plt.scatter(kappa, pred)

lims = [
    min(kappa.min(), pred.min()),
    max(kappa.max(), pred.max())
]

plt.plot(lims, lims)

plt.xlabel("LAMMPS Thermal Conductivity (W/mK)")
plt.ylabel("RK Predicted Conductivity (W/mK)")

plt.title("Redlich-Kister Fit 3 Parity")

plt.tight_layout()

plt.savefig(
    "rk_fit3_parity.png",
    dpi=300
)

plt.close()



